{
  "name": "javamind-ai",
  "private": true,
  "version": "0.1.0",
  "description": "Java IDE with integrated Claude AI learning platform",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "concurrently -k \"cross-env VITE_DEV=true vite --port 5173 --strictPort\" \"wait-on http://localhost:5173 && cross-env ELECTRON_DEV=true VITE_DEV_PORT=5173 electron .\"",
    "dev:renderer": "vite",
    "build:renderer": "tsc -b && vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "build": "npm run build:renderer && npm run build:electron && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/generative-ai": "^0.24.1",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dotenv": "^17.3.1",
    "openai": "^6.26.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.1",
    "react-syntax-highlighter": "^16.1.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.javamind.ai",
    "productName": "JavaMind AI",
    "directories": {
      "output": "dist/app"
    },
    "files": [
      "dist/renderer/**",
      "electron/dist/**",
      "node_modules/**",
      "!node_modules/.cache"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
